{
  "name": "wingman-vscode",
  "publisher": "adrianliechti",
  "displayName": "Wingman AI",
  "description": "Wingman AI",
  "version": "0.2.1",
  "icon": "assets/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianliechti/wingman-vscode"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onLanguageModelChat:wingman",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wingman.openAgent",
        "title": "Wingman Agent",
        "category": "Wingman",
        "icon": "$(rocket)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "wingman.openAgent",
          "when": "wingman.agentAvailable"
        }
      ]
    },
    "terminal": {
      "profiles": [
        {
          "id": "wingman.agent",
          "title": "Wingman Agent",
          "icon": "rocket"
        }
      ]
    },
    "configuration": {
      "title": "Wingman",
      "properties": {
        "wingman.baseUrl": {
          "type": "string",
          "default": "http://localhost:4242/v1",
          "scope": "machine"
        },
        "wingman.apiKey": {
          "type": "string",
          "default": "",
          "scope": "machine"
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "wingman",
        "displayName": "Wingman"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "build": "node esbuild.mjs --production",
    "pretest": "tsc -p ./ && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.15",
    "openai": "^6.34.0"
  }
}
